RewriteEngine On

# Backward compatibility for old local-style URLs deployed on the domain root.
RewriteRule ^Wikanda_Hair_Salon/public/?$ / [R=302,L]
RewriteRule ^Wikanda_Hair_Salon/public/(.*)$ /$1 [R=302,L]

# Protect system folders
RewriteRule ^(app|config|data|database|storage)/ - [F,L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]

# Protect sensitive files
<FilesMatch "^\.(env|json|lock|log)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Disable directory listing
Options -Indexes
